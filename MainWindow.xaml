<Window x:Class="Hanime1Downloader.CSharp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Hanime1视频工具"
        Height="760"
        Width="1160"
        MinHeight="640"
        MinWidth="960"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource ThemeWindowBackgroundBrush}">
    <Window.Resources>
        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource ThemeSurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
        </Style>

        <Style x:Key="PanelHeaderTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextPrimaryBrush}"/>
        </Style>

        <Style x:Key="ToolbarButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="26"/>
            <Setter Property="Padding" Value="7,0"/>
            <Setter Property="Background" Value="{DynamicResource ThemeButtonBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeButtonBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeButtonForegroundBrush}"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource ThemeButtonHoverBrush}"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource ThemeBorderStrongBrush}"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{DynamicResource ThemeButtonPressedBrush}"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.55"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PrimaryToolbarButtonStyle" TargetType="Button" BasedOn="{StaticResource ToolbarButtonStyle}">
            <Setter Property="Background" Value="{DynamicResource ThemeAccentBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeAccentBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeAccentForegroundBrush}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource ThemeAccentHoverBrush}"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource ThemeAccentHoverBrush}"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{DynamicResource ThemeAccentPressedBrush}"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource ThemeAccentPressedBrush}"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.55"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryActionButtonStyle" TargetType="Button" BasedOn="{StaticResource ToolbarButtonStyle}">
            <Setter Property="Height" Value="24"/>
            <Setter Property="Padding" Value="7,0"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>

        <Style x:Key="PrimaryActionButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryToolbarButtonStyle}">
            <Setter Property="Height" Value="24"/>
            <Setter Property="Padding" Value="7,0"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>

        <Style x:Key="SectionGroupBoxStyle" TargetType="GroupBox">
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextBrush}"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GroupBox">
                        <Grid SnapsToDevicePixels="True">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="1"
                                    Margin="0,1,0,0"
                                    Background="{DynamicResource ThemeSurfaceAltBrush}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="2"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter/>
                            </Border>
                            <Border Margin="7,0,0,0"
                                    Padding="3,0"
                                    Background="{DynamicResource ThemeWindowBackgroundBrush}"
                                    HorizontalAlignment="Left">
                                <ContentPresenter ContentSource="Header"
                                                  RecognizesAccessKey="True"
                                                  TextElement.FontWeight="SemiBold"
                                                  TextElement.FontSize="11"
                                                  TextElement.Foreground="{DynamicResource ThemeTextMutedBrush}"/>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PanelTabControlStyle" TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style x:Key="PanelTabItemStyle" TargetType="TabItem">
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextSecondaryBrush}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="7,3"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder"
                                Margin="0,0,2,0"
                                Padding="{TemplateBinding Padding}"
                                Background="{DynamicResource ThemeSurfaceSubtleBrush}"
                                BorderBrush="{DynamicResource ThemeBorderChromeBrush}"
                                BorderThickness="1"
                                CornerRadius="2,2,0,0">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource ThemeSurfaceBrush}"/>
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="{DynamicResource ThemeBorderStrongBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource ThemeTextBrush}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="{DynamicResource ThemeBorderStrongBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InteractiveListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemHost"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="2,0,0,0"
                                CornerRadius="0"
                                Padding="0">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemHost" Property="Background" Value="{DynamicResource ThemeSurfaceHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemHost" Property="Background" Value="{DynamicResource ThemeSelectionBrush}"/>
                                <Setter TargetName="ItemHost" Property="BorderBrush" Value="{DynamicResource ThemeSelectionBorderBrush}"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected" Value="True"/>
                                    <Condition Property="Selector.IsSelectionActive" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="ItemHost" Property="Background" Value="{DynamicResource ThemeSelectionInactiveBrush}"/>
                                <Setter TargetName="ItemHost" Property="BorderBrush" Value="{DynamicResource ThemeSelectionInactiveBorderBrush}"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CardListBoxStyle" TargetType="ListBox">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ScrollViewer.CanContentScroll" Value="True"/>
            <Setter Property="VirtualizingPanel.IsVirtualizing" Value="True"/>
            <Setter Property="VirtualizingPanel.VirtualizationMode" Value="Recycling"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource InteractiveListBoxItemStyle}"/>
        </Style>

        <Style x:Key="ColumnSplitterStyle" TargetType="GridSplitter">
            <Setter Property="Width" Value="5"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="ResizeDirection" Value="Columns"/>
            <Setter Property="ResizeBehavior" Value="PreviousAndNext"/>
            <Setter Property="ShowsPreview" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GridSplitter">
                        <Grid Background="Transparent">
                            <Border Width="1"
                                    HorizontalAlignment="Center"
                                    Background="{DynamicResource ThemeBorderBrush}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.9"/>
                </Trigger>
                <Trigger Property="IsKeyboardFocused" Value="True">
                    <Setter Property="Opacity" Value="0.9"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="FormLabelStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Top"/>
            <Setter Property="Margin" Value="0,2,10,2"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextSubtleBrush}"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>

        <Style x:Key="FormValueTextStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Top"/>
            <Setter Property="Margin" Value="0,2,0,2"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextBrush}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Margin="0,3,0,0"
                Style="{StaticResource CardBorderStyle}"
                Padding="7">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="50"/>
                        <ColumnDefinition Width="4"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="4"/>
                        <ColumnDefinition Width="56"/>
                        <ColumnDefinition Width="4"/>
                        <ColumnDefinition Width="50"/>
                        <ColumnDefinition Width="4"/>
                        <ColumnDefinition Width="50"/>
                        <ColumnDefinition Width="4"/>
                        <ColumnDefinition Width="50"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource ThemeTextSecondaryBrush}"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Text="搜索"/>

                    <Border Grid.Column="2"
                            Padding="6,1"
                            Background="{DynamicResource ThemeButtonBackgroundBrush}"
                            BorderBrush="{DynamicResource ThemeInputBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="2">
                        <TextBox x:Name="SearchBox"
                                 Height="26"
                                 FontSize="11"
                                 Padding="3,0"
                                 VerticalContentAlignment="Center"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 ToolTip="输入标题或粘贴 watch 链接"
                                 PreviewKeyDown="SearchBox_OnKeyDown"/>
                    </Border>

                    <Button x:Name="SearchButton"
                            Grid.Column="4"
                            Style="{StaticResource PrimaryToolbarButtonStyle}"
                            Content="搜索"
                            Click="SearchButton_OnClick"/>

                    <Button x:Name="FilterButton"
                            Grid.Column="6"
                            Style="{StaticResource ToolbarButtonStyle}"
                            Content="筛选"
                            Click="FilterButton_OnClick"/>

                    <Button x:Name="SettingsButton"
                            Grid.Column="8"
                            Style="{StaticResource ToolbarButtonStyle}"
                            Content="设置"
                            Click="SettingsButton_OnClick"/>

                    <Button x:Name="VerifyButton"
                            Grid.Column="10"
                            Style="{StaticResource ToolbarButtonStyle}"
                            Content="验证"
                            Click="VerifyButton_OnClick"/>

                </Grid>

                <Border x:Name="ActiveFilterSummaryPanel"
                        Grid.Row="1"
                        Margin="0,3,0,0"
                        Padding="7,4"
                        Background="{DynamicResource ThemeSummaryPanelBrush}"
                        BorderBrush="{DynamicResource ThemeSummaryPanelBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="2"
                        Visibility="Collapsed">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource ThemeTextNeutralBrush}"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Text="筛选"/>
                        <TextBlock x:Name="ActiveFilterSummaryText"
                                   Grid.Column="1"
                                   Margin="8,0,0,0"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource ThemeButtonForegroundBrush}"
                                   FontSize="11"
                                   Text=""
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock x:Name="ActiveFilterCountText"
                                   Grid.Column="2"
                                   Margin="10,0,0,0"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource ThemeTextMutedBrush}"
                                   FontSize="11"
                                   Text="0 项"/>
                        <Button x:Name="ClearFiltersButton"
                                Grid.Column="3"
                                Width="62"
                                Margin="8,0,0,0"
                                Style="{StaticResource SecondaryActionButtonStyle}"
                                Content="清空"
                                Click="ClearFiltersButton_OnClick"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,5,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.02*" MinWidth="236"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition x:Name="InfoColumn" Width="1.4*" MinWidth="374"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="0.88*" MinWidth="180"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Style="{StaticResource CardBorderStyle}"
                    Padding="7">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <DockPanel LastChildFill="False">
                        <TextBlock DockPanel.Dock="Left"
                                   Text="资源"
                                   Style="{StaticResource PanelHeaderTextStyle}"/>
                    </DockPanel>

                    <TabControl x:Name="LeftTabControl"
                                Grid.Row="1"
                                Margin="0,6,0,0"
                                Style="{StaticResource PanelTabControlStyle}">
                        <TabControl.Resources>
                            <Style TargetType="TabItem" BasedOn="{StaticResource PanelTabItemStyle}"/>
                        </TabControl.Resources>

                        <TabItem Header="搜索结果">
                            <Grid Margin="0,6,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <ListBox x:Name="ResultsList"
                                         Style="{StaticResource CardListBoxStyle}"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         SelectionMode="Extended"
                                         SelectionChanged="ResultsList_OnSelectionChanged"
                                         MouseDoubleClick="ResultsList_OnMouseDoubleClick"
                                         MouseRightButtonUp="ResultsList_OnMouseRightButtonUp"
                                         PreviewMouseLeftButtonDown="ListBox_PreviewMouseLeftButtonDown"
                                         PreviewMouseMove="ListBox_PreviewMouseMove"
                                         PreviewMouseLeftButtonUp="ListBox_PreviewMouseLeftButtonUp">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="3,1"
                                                    Background="{DynamicResource ThemeSurfaceBrush}"
                                                    BorderBrush="{DynamicResource ThemeBorderSubtleBrush}"
                                                    BorderThickness="0,0,0,1">
                                                <DockPanel LastChildFill="True">
                                                    <Border DockPanel.Dock="Left"
                                                            Width="64"
                                                            Height="36"
                                                            Margin="0,0,6,0"
                                                            Background="{DynamicResource ThemeCoverPlaceholderBrush}"
                                                            BorderBrush="{DynamicResource ThemeCoverPlaceholderBorderBrush}"
                                                            BorderThickness="1"
                                                            CornerRadius="2"
                                                            Visibility="{Binding DataContext.ShowListCoversVisibility, RelativeSource={RelativeSource AncestorType=Window}}">
                                                        <Image Source="{Binding CoverImage}" Stretch="UniformToFill"/>
                                                    </Border>
                                                    <TextBlock Text="{Binding Title}"
                                                               VerticalAlignment="Center"
                                                               Foreground="{DynamicResource ThemeTextBrush}"
                                                               FontSize="11"
                                                               TextWrapping="NoWrap"
                                                               TextTrimming="CharacterEllipsis"/>
                                                </DockPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                                <Border Grid.Row="1"
                                        Margin="0,2,0,0"
                                        Padding="1,3,1,0"
                                        Background="Transparent"
                                        BorderBrush="{DynamicResource ThemeBorderSubtleBrush}"
                                        BorderThickness="0,1,0,0"
                                        CornerRadius="0">
                                    <StackPanel>
                                        <WrapPanel HorizontalAlignment="Center">
                                            <Button x:Name="FirstPageButton"
                                                    Width="38"
                                                    Margin="0,0,3,0"
                                                    Style="{StaticResource SecondaryActionButtonStyle}"
                                                    Content="首"
                                                    Click="FirstPageButton_OnClick"/>
                                            <Button x:Name="PreviousPageButton"
                                                    Width="44"
                                                    Margin="0,0,3,0"
                                                    Style="{StaticResource SecondaryActionButtonStyle}"
                                                    Content="上页"
                                                    Click="PreviousPageButton_OnClick"/>
                                            <Button x:Name="PageButton1"
                                                    Width="28"
                                                    Margin="0,0,3,0"
                                                    Style="{StaticResource SecondaryActionButtonStyle}"
                                                    Click="PageNumberButton_OnClick"/>
                                            <Button x:Name="PageButton2"
                                                    Width="28"
                                                    Margin="0,0,3,0"
                                                    Style="{StaticResource SecondaryActionButtonStyle}"
                                                    Click="PageNumberButton_OnClick"/>
                                            <Button x:Name="PageButton3"
                                                    Width="28"
                                                    Margin="0,0,3,0"
                                                    Style="{StaticResource SecondaryActionButtonStyle}"
                                                    Click="PageNumberButton_OnClick"/>
                                            <Button x:Name="PageButton4"
                                                    Width="28"
                                                    Margin="0,0,3,0"
                                                    Style="{StaticResource SecondaryActionButtonStyle}"
                                                    Click="PageNumberButton_OnClick"/>
                                            <Button x:Name="PageButton5"
                                                    Width="28"
                                                    Margin="0,0,3,0"
                                                    Style="{StaticResource SecondaryActionButtonStyle}"
                                                    Click="PageNumberButton_OnClick"/>
                                            <Button x:Name="NextPageButton"
                                                    Width="44"
                                                    Margin="0,0,3,0"
                                                    Style="{StaticResource SecondaryActionButtonStyle}"
                                                    Content="下页"
                                                    Click="NextPageButton_OnClick"/>
                                            <Button x:Name="LastPageButton"
                                                    Width="38"
                                                    Style="{StaticResource SecondaryActionButtonStyle}"
                                                    Content="末"
                                                    Click="LastPageButton_OnClick"/>
                                        </WrapPanel>
                                        <TextBlock x:Name="PageNavigationLabel"
                                                   Margin="0,2,0,0"
                                                   HorizontalAlignment="Center"
                                                   Foreground="{DynamicResource ThemeTextMutedBrush}"
                                                   FontSize="10"
                                                   Text="1 / 1"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </TabItem>

                        <TabItem Header="收藏夹">
                            <Grid Margin="0,6,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="6"/>
                                        <ColumnDefinition Width="64"/>
                                        <ColumnDefinition Width="6"/>
                                        <ColumnDefinition Width="64"/>
                                        <ColumnDefinition Width="6"/>
                                        <ColumnDefinition Width="76"/>
                                    </Grid.ColumnDefinitions>

                                    <ComboBox x:Name="FavoritesFolderBox"
                                              Grid.Column="0"
                                              Height="28"
                                              VerticalContentAlignment="Center"
                                              SelectionChanged="FavoritesFolderBox_OnSelectionChanged"/>
                                    <Button Grid.Column="2"
                                            Style="{StaticResource SecondaryActionButtonStyle}"
                                            Content="新建"
                                            Click="NewFavoriteFolderButton_OnClick"/>
                                    <Button Grid.Column="4"
                                            Style="{StaticResource SecondaryActionButtonStyle}"
                                            Content="删除"
                                            Click="DeleteFavoriteFolderButton_OnClick"/>
                                    <Button Grid.Column="6"
                                            Style="{StaticResource SecondaryActionButtonStyle}"
                                            Content="重命名"
                                            Click="RenameFavoriteFolderButton_OnClick"/>
                                </Grid>

                                <Grid Grid.Row="1" Margin="0,6,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="6"/>
                                        <ColumnDefinition Width="66"/>
                                        <ColumnDefinition Width="6"/>
                                        <ColumnDefinition Width="66"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBox x:Name="FavoritesSearchBox"
                                             Grid.Column="0"
                                             Height="28"
                                             VerticalContentAlignment="Center"
                                             Padding="7,0"
                                             ToolTip="在收藏夹中搜索..."
                                             TextChanged="FavoritesSearchBox_OnTextChanged"/>
                                    <Button Grid.Column="2"
                                            Style="{StaticResource SecondaryActionButtonStyle}"
                                            Content="导出"
                                            Click="ExportFavoritesButton_OnClick"/>
                                    <Button Grid.Column="4"
                                            Style="{StaticResource SecondaryActionButtonStyle}"
                                            Content="导入"
                                            Click="ImportFavoritesButton_OnClick"/>
                                </Grid>

                                <ListBox x:Name="FavoritesList"
                                         Grid.Row="2"
                                         Style="{StaticResource CardListBoxStyle}"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         SelectionMode="Extended"
                                         SelectionChanged="FavoritesList_OnSelectionChanged"
                                         MouseRightButtonUp="FavoritesList_OnMouseRightButtonUp"
                                         PreviewMouseLeftButtonDown="ListBox_PreviewMouseLeftButtonDown"
                                         PreviewMouseMove="ListBox_PreviewMouseMove"
                                         PreviewMouseLeftButtonUp="ListBox_PreviewMouseLeftButtonUp">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="3,1"
                                                    Background="{DynamicResource ThemeSurfaceBrush}"
                                                    BorderBrush="{DynamicResource ThemeBorderSubtleBrush}"
                                                    BorderThickness="0,0,0,1">
                                                <DockPanel LastChildFill="True">
                                                    <Border DockPanel.Dock="Left"
                                                            Width="64"
                                                            Height="36"
                                                            Margin="0,0,6,0"
                                                            Background="{DynamicResource ThemeCoverPlaceholderBrush}"
                                                            BorderBrush="{DynamicResource ThemeCoverPlaceholderBorderBrush}"
                                                            BorderThickness="1"
                                                            CornerRadius="2"
                                                            Visibility="{Binding DataContext.ShowListCoversVisibility, RelativeSource={RelativeSource AncestorType=Window}}">
                                                        <Image Source="{Binding CoverImage}" Stretch="UniformToFill"/>
                                                    </Border>
                                                    <TextBlock Text="{Binding Title}"
                                                               VerticalAlignment="Center"
                                                               Foreground="{DynamicResource ThemeTextBrush}"
                                                               FontSize="11"
                                                               TextWrapping="NoWrap"
                                                               TextTrimming="CharacterEllipsis"/>
                                                </DockPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </TabItem>

                        <TabItem Header="下载历史">
                            <Grid Margin="0,6,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <StackPanel Orientation="Horizontal">
                                    <Button Width="72"
                                            Style="{StaticResource SecondaryActionButtonStyle}"
                                            Content="刷新"
                                            Click="RefreshHistoryButton_OnClick"/>
                                    <Button Width="84"
                                            Margin="6,0,0,0"
                                            Style="{StaticResource SecondaryActionButtonStyle}"
                                            Content="清空"
                                            Click="ClearHistoryButton_OnClick"/>
                                </StackPanel>

                                <TextBox x:Name="HistorySearchBox"
                                         Grid.Row="1"
                                         Height="28"
                                         Margin="0,6,0,0"
                                         VerticalContentAlignment="Center"
                                         Padding="7,0"
                                         ToolTip="在下载历史中搜索..."
                                         TextChanged="HistorySearchBox_OnTextChanged"/>

                                <ListBox x:Name="HistoryList"
                                         Grid.Row="2"
                                         Margin="0,6,0,0"
                                         Style="{StaticResource CardListBoxStyle}"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         SelectionMode="Extended"
                                         SelectionChanged="HistoryList_OnSelectionChanged"
                                         PreviewMouseRightButtonDown="HistoryList_OnPreviewMouseRightButtonDown"
                                         MouseRightButtonUp="HistoryList_OnMouseRightButtonUp"
                                         PreviewMouseLeftButtonDown="ListBox_PreviewMouseLeftButtonDown"
                                         PreviewMouseMove="ListBox_PreviewMouseMove"
                                         PreviewMouseLeftButtonUp="ListBox_PreviewMouseLeftButtonUp">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="4,2"
                                                    Background="{DynamicResource ThemeSurfaceBrush}"
                                                    BorderBrush="{DynamicResource ThemeBorderSubtleBrush}"
                                                    BorderThickness="0,0,0,1">
                                                <StackPanel>
                                                    <DockPanel LastChildFill="False">
                                                        <Border DockPanel.Dock="Right"
                                                                Padding="4,1"
                                                                Margin="6,0,0,0"
                                                                CornerRadius="2">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Background" Value="{DynamicResource ThemeSuccessSoftBrush}"/>
                                                                    <Setter Property="BorderBrush" Value="{DynamicResource ThemeSuccessBorderBrush}"/>
                                                                    <Setter Property="BorderThickness" Value="1"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding FileExists}" Value="False">
                                                                            <Setter Property="Background" Value="{DynamicResource ThemeErrorSoftBrush}"/>
                                                                            <Setter Property="BorderBrush" Value="{DynamicResource ThemeErrorBorderBrush}"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <TextBlock Text="{Binding FileStateText}"
                                                                       FontSize="10">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Foreground" Value="{DynamicResource ThemeSuccessTextBrush}"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding FileExists}" Value="False">
                                                                                <Setter Property="Foreground" Value="{DynamicResource ThemeErrorTextBrush}"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                        </Border>
                                                        <TextBlock Text="{Binding FileName}"
                                                                   Foreground="{DynamicResource ThemeTextBrush}"
                                                                   FontSize="11"
                                                                   TextWrapping="NoWrap"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                    </DockPanel>
                                                    <TextBlock Text="{Binding TimeText}"
                                                               Foreground="{DynamicResource ThemeTextMutedBrush}"
                                                               FontSize="10"
                                                               Margin="0,1,0,0"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </TabItem>
                    </TabControl>
                    <TextBlock x:Name="StatusText"
                               Grid.Row="2"
                               Margin="0,4,0,0"
                               Foreground="{DynamicResource ThemeTextMutedBrush}"
                               FontSize="10"
                               Text="请先完成 Cloudflare 验证。"
                               TextWrapping="NoWrap"
                               TextTrimming="CharacterEllipsis"
                               MaxHeight="14"
                               ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"/>
                </Grid>
            </Border>

            <Border x:Name="InfoPanel" Grid.Column="2"
                    Style="{StaticResource CardBorderStyle}"
                    Padding="7">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="0.55*" MinHeight="60"/>
                        <RowDefinition Height="*" MinHeight="80"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <DockPanel LastChildFill="False">
                        <TextBlock DockPanel.Dock="Left"
                                   Text="信息"
                                   Style="{StaticResource PanelHeaderTextStyle}"/>
                        <TextBlock DockPanel.Dock="Left"
                                   Margin="10,1,0,0"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource ThemeTextMutedBrush}"
                                   FontSize="10"
                                   Text="基础信息"/>
                        <WrapPanel DockPanel.Dock="Right">
                            <Button x:Name="ViewDescriptionButton"
                                    Width="52"
                                    Margin="0,0,3,0"
                                    Style="{StaticResource SecondaryActionButtonStyle}"
                                    Content="简介"
                                    Click="ViewDescriptionButton_OnClick"/>
                            <Button x:Name="PreviewCoverButton"
                                    Width="64"
                                    Margin="0,0,3,0"
                                    Style="{StaticResource SecondaryActionButtonStyle}"
                                    Content="查看封面"
                                    Click="PreviewCoverButton_OnClick"/>
                            <Button x:Name="AddFavoriteButton"
                                    Width="64"
                                    Style="{StaticResource SecondaryActionButtonStyle}"
                                    Content="收藏"
                                    Click="AddFavoriteButton_OnClick"/>
                        </WrapPanel>
                    </DockPanel>

                    <Border Grid.Row="1"
                            Margin="0,3,0,0"
                            Padding="6,3"
                            Background="{DynamicResource ThemeSurfaceAltBrush}"
                            BorderBrush="{DynamicResource ThemeBorderAltBrush}"
                            BorderThickness="1"
                            CornerRadius="2">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="62"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Style="{StaticResource FormLabelStyle}" Text="标题"/>
                            <Grid Grid.Row="0" Grid.Column="1">
                                <TextBlock x:Name="TitleText"
                                           Style="{StaticResource FormValueTextStyle}"
                                           Text="请选择左侧视频查看详情。"
                                           TextWrapping="NoWrap"
                                           TextTrimming="CharacterEllipsis"
                                           Cursor="Hand"
                                           MouseLeftButtonDown="TitleText_OnMouseLeftButtonDown"/>
                                <Canvas IsHitTestVisible="False">
                                    <TextBlock x:Name="TitleCopiedHint"
                                               Style="{StaticResource FormValueTextStyle}"
                                               Text="已复制"
                                               Visibility="Collapsed"
                                               Background="{DynamicResource ThemeSurfaceBrush}"
                                               Padding="4,1"/>
                                </Canvas>
                            </Grid>

                            <TextBlock x:Name="UploadDateLabel"
                                       Grid.Row="1"
                                       Style="{StaticResource FormLabelStyle}"
                                       Text="上传时间"/>
                            <TextBlock x:Name="UploadDateText"
                                       Grid.Row="1"
                                       Grid.Column="1"
                                       Style="{StaticResource FormValueTextStyle}"
                                       Text="-"/>

                            <TextBlock x:Name="LikesLabel"
                                       Grid.Row="2"
                                       Style="{StaticResource FormLabelStyle}"
                                       Text="点赞"/>
                            <TextBlock x:Name="LikesText"
                                       Grid.Row="2"
                                       Grid.Column="1"
                                       Style="{StaticResource FormValueTextStyle}"
                                       Text="-"/>

                            <TextBlock x:Name="ViewsLabel"
                                       Grid.Row="3"
                                       Style="{StaticResource FormLabelStyle}"
                                       Text="观看"/>
                            <TextBlock x:Name="ViewsText"
                                       Grid.Row="3"
                                       Grid.Column="1"
                                       Style="{StaticResource FormValueTextStyle}"
                                       Text="-"/>

                            <TextBlock x:Name="DurationLabel"
                                       Grid.Row="4"
                                       Style="{StaticResource FormLabelStyle}"
                                       Text="时长"/>
                            <TextBlock x:Name="DurationText"
                                       Grid.Row="4"
                                       Grid.Column="1"
                                       Style="{StaticResource FormValueTextStyle}"
                                       Text="-"/>

                            <TextBlock x:Name="TagsLabel"
                                       Grid.Row="5"
                                       Style="{StaticResource FormLabelStyle}"
                                       Text="标签"/>
                            <TextBlock x:Name="TagsText"
                                       Grid.Row="5"
                                       Grid.Column="1"
                                       Style="{StaticResource FormValueTextStyle}"
                                       Text="-"/>
                        </Grid>
                    </Border>

                    <GroupBox Grid.Row="2"
                              Margin="0,2,0,0"
                              Header="相关视频"
                              Style="{StaticResource SectionGroupBoxStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <ListBox x:Name="RelatedList"
                                     Style="{StaticResource CardListBoxStyle}"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     SelectionMode="Extended"
                                     SelectionChanged="RelatedList_OnSelectionChanged"
                                     MouseDoubleClick="RelatedList_OnMouseDoubleClick"
                                     MouseRightButtonUp="RelatedList_OnMouseRightButtonUp"
                                     PreviewMouseLeftButtonDown="ListBox_PreviewMouseLeftButtonDown"
                                     PreviewMouseMove="ListBox_PreviewMouseMove"
                                     PreviewMouseLeftButtonUp="ListBox_PreviewMouseLeftButtonUp">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="3,1"
                                                Background="{DynamicResource ThemeSurfaceBrush}"
                                                BorderBrush="{DynamicResource ThemeBorderSubtleBrush}"
                                                BorderThickness="0,0,0,1">
                                            <TextBlock Text="{Binding Title}"
                                                       Foreground="{DynamicResource ThemeTextBrush}"
                                                       FontSize="11"
                                                       TextWrapping="NoWrap"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <TextBlock Grid.Row="1"
                                       Margin="0,2,0,0"
                                       Foreground="{DynamicResource ThemeTextMutedBrush}"
                                       FontSize="11"
                                       Text="双击或右键可使用相关视频"/>
                        </Grid>
                    </GroupBox>

                    <GroupBox Grid.Row="3"
                              Margin="0,2,0,0"
                              Header="视频源"
                              Style="{StaticResource SectionGroupBoxStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock x:Name="SourcesSummaryText"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource ThemeTextMutedBrush}"
                                       FontSize="11"
                                       Text="未加载视频源"/>

                            <ListBox x:Name="SourcesList"
                                     Grid.Row="1"
                                     Margin="0,3,0,0"
                                     Style="{StaticResource CardListBoxStyle}"
                                     SelectionChanged="SourcesList_OnSelectionChanged"
                                     MouseDoubleClick="SourcesList_OnMouseDoubleClick">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="3,1"
                                                Background="{DynamicResource ThemeSurfaceBrush}"
                                                BorderBrush="{DynamicResource ThemeBorderSubtleBrush}"
                                                BorderThickness="0,0,0,1">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="52"/>
                                                    <ColumnDefinition Width="5"/>
                                                    <ColumnDefinition Width="52"/>
                                                    <ColumnDefinition Width="5"/>
                                                    <ColumnDefinition Width="52"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding QualityText}"
                                                               Foreground="{DynamicResource ThemeTextBrush}"
                                                               FontSize="11"
                                                               TextWrapping="NoWrap"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Margin="0,1,0,0"
                                                               Foreground="{DynamicResource ThemeTextMutedBrush}"
                                                               FontSize="10"
                                                               Text="{Binding TypeText}"/>
                                                </StackPanel>
                                                <Button Grid.Column="1"
                                                        Height="20"
                                                        Tag="{Binding}"
                                                        Style="{StaticResource SecondaryActionButtonStyle}"
                                                        Content="播放"
                                                        Click="PlaySourceInline_OnClick"/>
                                                <Button Grid.Column="3"
                                                        Height="20"
                                                        Tag="{Binding}"
                                                        Style="{StaticResource SecondaryActionButtonStyle}"
                                                        Content="队列"
                                                        Click="QueueSourceInline_OnClick"/>
                                                <Button Grid.Column="5"
                                                        Height="20"
                                                        Tag="{Binding}"
                                                        Style="{StaticResource SecondaryActionButtonStyle}"
                                                        Content="下载"
                                                        Click="DownloadSourceInline_OnClick"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <WrapPanel Grid.Row="2"
                                       Margin="0,3,0,0"
                                       HorizontalAlignment="Right">
                                <Button x:Name="QueueSourceButton"
                                        Width="76"
                                        Margin="0,0,5,0"
                                        Style="{StaticResource PrimaryActionButtonStyle}"
                                        Content="入队"
                                        Click="QueueSourceButton_OnClick"/>
                                <Button x:Name="DownloadButton"
                                        Width="68"
                                        Style="{StaticResource SecondaryActionButtonStyle}"
                                        Content="下载"
                                        Click="DownloadButton_OnClick"/>
                            </WrapPanel>
                        </Grid>
                    </GroupBox>

                    <Border Grid.Row="4"
                            Margin="0,4,0,0"
                            Padding="6,4"
                            Background="{DynamicResource ThemeSurfaceAltBrush}"
                            BorderBrush="{DynamicResource ThemeBorderAltBrush}"
                            BorderThickness="1"
                            CornerRadius="2">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="32"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource ThemeTextSubtleBrush}"
                                       FontSize="11"
                                       Text="链接"/>
                            <TextBlock x:Name="UrlText"
                                       Grid.Column="1"
                                       Margin="6,0,8,0"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource ThemeTextMutedBrush}"
                                       FontSize="11"
                                       TextWrapping="NoWrap"
                                       TextTrimming="CharacterEllipsis"
                                       ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"/>
                            <Button x:Name="CopyUrlButton"
                                    Grid.Column="2"
                                    Width="52"
                                    Margin="0,0,5,0"
                                    Style="{StaticResource SecondaryActionButtonStyle}"
                                    Content="复制"
                                    Click="CopyVideoUrlButton_OnClick"/>
                            <Button x:Name="OpenVideoPageButton"
                                    Grid.Column="3"
                                    Width="52"
                                    Style="{StaticResource SecondaryActionButtonStyle}"
                                    Content="打开"
                                    Click="OpenVideoPageButton_OnClick"/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Column="4"
                    Style="{StaticResource CardBorderStyle}"
                    Padding="7">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <DockPanel LastChildFill="False">
                        <TextBlock DockPanel.Dock="Left"
                                   Text="下载"
                                   Style="{StaticResource PanelHeaderTextStyle}"/>
                        <TextBlock x:Name="QueueCountText"
                                   DockPanel.Dock="Right"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource ThemeTextMutedBrush}"
                                   FontSize="10"
                                   Text="队列"/>
                    </DockPanel>

                    <StackPanel Grid.Row="1" Margin="0,3,0,0">
                        <TextBlock x:Name="QueueSummaryText"
                                   Foreground="{DynamicResource ThemeTextMutedBrush}"
                                   FontSize="10"
                                   Text="待处理 0 项"
                                   TextWrapping="NoWrap"
                                   TextTrimming="CharacterEllipsis"
                                   ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"/>
                        <TextBlock x:Name="QueueCurrentTitleText"
                                   Margin="0,1,0,0"
                                   Foreground="{DynamicResource ThemeTextTertiaryBrush}"
                                   FontSize="10"
                                   Text=""
                                   TextWrapping="NoWrap"
                                   TextTrimming="CharacterEllipsis"
                                   ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"
                                   Visibility="Collapsed"/>
                        <ProgressBar x:Name="QueueOverallProgressBar"
                                     Height="4"
                                     Margin="0,3,0,0"
                                     Minimum="0"
                                     Maximum="100"
                                     Visibility="Collapsed"/>
                    </StackPanel>

                    <ListBox x:Name="DownloadQueueList"
                             Grid.Row="2"
                             Margin="0,3,0,0"
                             Style="{StaticResource CardListBoxStyle}"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             SelectionMode="Extended"
                             AllowDrop="True"
                             PreviewMouseRightButtonDown="DownloadQueueList_OnPreviewMouseRightButtonDown"
                             MouseRightButtonUp="DownloadQueueList_OnMouseRightButtonUp"
                             PreviewMouseLeftButtonDown="ListBox_PreviewMouseLeftButtonDown"
                             PreviewMouseMove="ListBox_PreviewMouseMove"
                             PreviewMouseLeftButtonUp="ListBox_PreviewMouseLeftButtonUp"
                             DragOver="DownloadQueueList_OnDragOver"
                             Drop="DownloadQueueList_OnDrop">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="3,2"
                                        BorderBrush="{DynamicResource ThemeBorderSubtleBrush}"
                                        BorderThickness="0,0,0,1">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{DynamicResource ThemeSurfaceBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsDownloading}" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource ThemeSuccessBrush}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding HasError}" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource ThemeErrorBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid ClipToBounds="True">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <DockPanel Grid.Row="0" LastChildFill="True" Margin="0,0,0,1">
                                            <Border DockPanel.Dock="Left"
                                                    Padding="3,1"
                                                    Margin="0,0,4,0"
                                                    Background="{DynamicResource ThemeBadgeInfoBrush}"
                                                    BorderBrush="{DynamicResource ThemeBadgeInfoBorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="2">
                                                <TextBlock Text="{Binding StageText}"
                                                           Foreground="{DynamicResource ThemeBadgeInfoTextBrush}"
                                                           FontSize="10"/>
                                            </Border>
                                            <TextBlock Text="{Binding Title}"
                                                       MinWidth="0"
                                                       VerticalAlignment="Center"
                                                       Foreground="{DynamicResource ThemeTextBrush}"
                                                       FontSize="11"
                                                       TextWrapping="NoWrap"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </DockPanel>

                                        <StackPanel Grid.Row="1"
                                                    Orientation="Horizontal"
                                                    HorizontalAlignment="Left">
                                            <Border Padding="3,1"
                                                    Background="{DynamicResource ThemeButtonPressedBrush}"
                                                    BorderBrush="{DynamicResource ThemeBadgeNeutralBorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="2">
                                                <TextBlock Text="{Binding TypeText}"
                                                           Foreground="{DynamicResource ThemeTextNeutralBrush}"
                                                           FontSize="10"/>
                                            </Border>
                                            <Border Padding="3,1"
                                                    Margin="3,0,0,0"
                                                    Background="{DynamicResource ThemeButtonPressedBrush}"
                                                    BorderBrush="{DynamicResource ThemeBadgeNeutralBorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="2">
                                                <TextBlock Text="{Binding QualityText}"
                                                           Foreground="{DynamicResource ThemeTextNeutralBrush}"
                                                           FontSize="10"/>
                                            </Border>
                                        </StackPanel>

                                        <TextBlock Grid.Row="2"
                                                   Margin="0,2,0,0"
                                                   Text="{Binding QueueStatusText}"
                                                   Foreground="{DynamicResource ThemeTextMutedBrush}"
                                                   FontSize="10"
                                                   TextWrapping="NoWrap"
                                                   TextTrimming="CharacterEllipsis"/>

                                        <ProgressBar Grid.Row="3"
                                                     Height="4"
                                                     Margin="0,3,0,0"
                                                     Minimum="0"
                                                     Maximum="100"
                                                     HorizontalAlignment="Stretch"
                                                     Value="{Binding ProgressValue, TargetNullValue=0}">
                                            <ProgressBar.Style>
                                                <Style TargetType="ProgressBar">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Setter Property="IsIndeterminate" Value="False"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ShowProgress}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsProgressIndeterminate}" Value="True">
                                                            <Setter Property="IsIndeterminate" Value="True"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ProgressBar.Style>
                                        </ProgressBar>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <WrapPanel Grid.Row="3"
                               Margin="0,3,0,0"
                               HorizontalAlignment="Right">
                        <Button x:Name="RetryFailedQueueItemsButton"
                                Width="84"
                                Margin="0,0,5,0"
                                Style="{StaticResource SecondaryActionButtonStyle}"
                                Content="重新解析失败项"
                                Click="ReResolveFailedQueueItemsButton_OnClick"/>
                        <Button x:Name="DownloadQueueButton"
                                Width="76"
                                Margin="0,0,5,0"
                                Style="{StaticResource PrimaryActionButtonStyle}"
                                Content="开始"
                                Click="DownloadQueueButton_OnClick"/>
                        <Button x:Name="ClearQueueButton"
                                Width="68"
                                Style="{StaticResource SecondaryActionButtonStyle}"
                                Content="清空"
                                Click="ClearQueueButton_OnClick"/>
                    </WrapPanel>
                </Grid>
            </Border>
        </Grid>

    </Grid>
</Window>