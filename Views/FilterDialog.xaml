<Window x:Class="Hanime1Downloader.CSharp.Views.FilterDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="筛选设置"
        Width="500"
        Height="560"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="{DynamicResource ThemeDialogBackgroundBrush}">
    <Window.Resources>
        <Style x:Key="SectionGroupStyle" TargetType="GroupBox" BasedOn="{StaticResource {x:Type GroupBox}}">
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Padding" Value="8,6,8,8"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeBorderBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextBrush}"/>
        </Style>
        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Width" Value="78"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="FilterRowStyle" TargetType="DockPanel">
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="LastChildFill" Value="True"/>
        </Style>
    </Window.Resources>

    <Grid Margin="10,10,10,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Padding="0,2,0,0">
                <StackPanel>
                    <GroupBox Header="基础筛选" Style="{StaticResource SectionGroupStyle}">
                        <StackPanel>
                            <DockPanel Style="{StaticResource FilterRowStyle}">
                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="影片类型:"/>
                                <Button DockPanel.Dock="Right" Width="52" Height="28" Margin="8,0,0,0" Click="ClearGenreButton_OnClick" Content="清空"/>
                                <ComboBox x:Name="GenreCombo" Height="28" DisplayMemberPath="Label" SelectedValuePath="Value" SelectionChanged="QuickFilterControl_OnChanged"/>
                            </DockPanel>
                            <DockPanel Style="{StaticResource FilterRowStyle}">
                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="排序方式:"/>
                                <Button DockPanel.Dock="Right" Width="52" Height="28" Margin="8,0,0,0" Click="ClearSortButton_OnClick" Content="清空"/>
                                <ComboBox x:Name="SortCombo" Height="28" DisplayMemberPath="Label" SelectedValuePath="Value" SelectionChanged="QuickFilterControl_OnChanged"/>
                            </DockPanel>
                            <DockPanel Style="{StaticResource FilterRowStyle}">
                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="发布日期:"/>
                                <Button DockPanel.Dock="Right" Width="52" Height="28" Margin="8,0,0,0" Click="ClearDateButton_OnClick" Content="清空"/>
                                <ComboBox x:Name="DateCombo" Height="28" DisplayMemberPath="Label" SelectedValuePath="Value" SelectionChanged="QuickFilterControl_OnChanged"/>
                            </DockPanel>
                            <DockPanel>
                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="时长:"/>
                                <Button DockPanel.Dock="Right" Width="52" Height="28" Margin="8,0,0,0" Click="ClearDurationButton_OnClick" Content="清空"/>
                                <ComboBox x:Name="DurationCombo" Height="28" DisplayMemberPath="Label" SelectedValuePath="Value" SelectionChanged="QuickFilterControl_OnChanged"/>
                            </DockPanel>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="标签" Style="{StaticResource SectionGroupStyle}">
                        <StackPanel>
                            <DockPanel Margin="0,0,0,8" LastChildFill="False">
                                <CheckBox x:Name="BroadCheckBox"
                                          VerticalAlignment="Center"
                                          Checked="QuickFilterControl_OnChanged"
                                          Unchecked="QuickFilterControl_OnChanged"
                                          Content="广泛配对"/>
                                <Button DockPanel.Dock="Right" Width="52" Height="28" Margin="8,0,0,0" Click="ClearTagsButton_OnClick" Content="清空"/>
                                <Button DockPanel.Dock="Right" Width="80" Height="28" Click="ChooseTagsButton_OnClick" Content="选择标签"/>
                            </DockPanel>
                            <TextBlock Margin="0,0,0,6" FontSize="12" Foreground="{DynamicResource ThemeTextNeutralBrush}" Text="已选标签:"/>
                            <Border MinHeight="88" Padding="8" Background="{DynamicResource ThemeSurfaceBrush}" BorderBrush="{DynamicResource ThemeBorderBrush}" BorderThickness="1">
                                <TextBlock x:Name="TagsSummaryText" FontSize="12" TextWrapping="Wrap"/>
                            </Border>
                        </StackPanel>
                    </GroupBox>

                </StackPanel>
            </ScrollViewer>

            <TextBlock Grid.Row="1"
                       x:Name="FilterStateText"
                       Margin="0,4,0,0"
                       FontSize="12"
                       Foreground="{DynamicResource ThemeTextNeutralBrush}"
                       Text="当前未启用额外筛选"/>
        </Grid>

        <Border Grid.Row="1" Margin="-10,8,-10,0" Padding="10,8,10,10" Background="{DynamicResource ThemeSurfaceFooterBrush}" BorderBrush="{DynamicResource ThemeBorderBrush}" BorderThickness="0,1,0,0">
            <DockPanel LastChildFill="False">
                <Button DockPanel.Dock="Left" Width="70" Height="32" Click="ResetButton_OnClick" Content="重置"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Width="70" Height="32" IsDefault="True" Click="ConfirmButton_OnClick" Content="保存" Background="{DynamicResource ThemeAccentBrush}" Foreground="{DynamicResource ThemeAccentForegroundBrush}" BorderBrush="{DynamicResource ThemeAccentBrush}"/>
                    <Button Width="70" Height="32" Margin="8,0,0,0" IsCancel="True" Content="取消"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>