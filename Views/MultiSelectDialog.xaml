<Window x:Class="Hanime1Downloader.CSharp.Views.MultiSelectDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="选择"
        Width="760"
        Height="680"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="{DynamicResource ThemeDialogBackgroundBrush}">
    <Window.Resources>
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource ThemeAccentBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeAccentBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeAccentForegroundBrush}"/>
        </Style>
    </Window.Resources>
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="PromptText"
                   Foreground="{DynamicResource ThemeTextBrush}"
                   FontSize="12"
                   TextWrapping="Wrap"/>

        <TextBox x:Name="SearchBox"
                 Grid.Row="1"
                 Margin="0,6,0,0"
                 Height="28"
                 VerticalContentAlignment="Center"
                 Padding="7,0"
                 TextChanged="SearchBox_OnTextChanged"
                 KeyDown="SearchBox_OnKeyDown"/>

        <DockPanel Grid.Row="2"
                   Margin="0,6,0,0"
                   LastChildFill="False">
            <TextBlock x:Name="SelectionSummaryText"
                       VerticalAlignment="Center"
                       FontSize="11"
                       Foreground="{DynamicResource ThemeTextMutedBrush}"/>
            <StackPanel DockPanel.Dock="Right"
                        Orientation="Horizontal">
                <Button x:Name="SelectVisibleButton"
                        Width="84"
                        Click="SelectVisibleButton_OnClick"
                        Content="全选结果"/>
                <Button x:Name="ClearVisibleButton"
                        Width="84"
                        Margin="6,0,0,0"
                        Click="ClearVisibleButton_OnClick"
                        Content="清空结果"/>
            </StackPanel>
        </DockPanel>

        <ScrollViewer x:Name="GroupScrollViewer"
                      Grid.Row="3"
                      Margin="0,6,0,0"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="GroupHost"/>
        </ScrollViewer>

        <StackPanel Grid.Row="4"
                    Margin="0,8,0,0"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Width="80"
                    Click="ResetButton_OnClick"
                    Content="重置"/>
            <Button Width="80"
                    Margin="6,0,0,0"
                    IsDefault="True"
                    Click="ConfirmButton_OnClick"
                    Content="确定"
                    Style="{StaticResource PrimaryButtonStyle}"/>
            <Button Width="80"
                    Margin="6,0,0,0"
                    IsCancel="True"
                    Content="取消"/>
        </StackPanel>
    </Grid>
</Window>
