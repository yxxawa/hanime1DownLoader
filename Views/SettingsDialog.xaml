<Window x:Class="Hanime1Downloader.CSharp.Views.SettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="设置"
        Width="520"
        Height="500"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="{DynamicResource ThemeDialogBackgroundBrush}">
    <Window.Resources>
        <Style x:Key="RowLabelStyle" TargetType="TextBlock">
            <Setter Property="Width" Value="112"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="FormRowStyle" TargetType="DockPanel">
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="LastChildFill" Value="True"/>
        </Style>
        <Style x:Key="SectionGroupStyle" TargetType="GroupBox" BasedOn="{StaticResource {x:Type GroupBox}}">
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Padding" Value="8,6,8,8"/>
        </Style>
        <Style x:Key="SettingsTabItemStyle" TargetType="TabItem">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="12,4"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextSecondaryBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder"
                                Margin="0,0,2,0"
                                Padding="{TemplateBinding Padding}"
                                Background="{DynamicResource ThemeSurfaceSubtleBrush}"
                                BorderBrush="{DynamicResource ThemeBorderChromeBrush}"
                                BorderThickness="1"
                                CornerRadius="2,2,0,0">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource ThemeSurfaceBrush}"/>
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="{DynamicResource ThemeBorderStrongBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource ThemeTextBrush}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="{DynamicResource ThemeBorderStrongBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="10,10,10,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0">
            <TabControl.Resources>
                <Style TargetType="TabItem" BasedOn="{StaticResource SettingsTabItemStyle}"/>
            </TabControl.Resources>
            <TabItem Header="下载设置">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="8,8,8,0">
                    <StackPanel>
                        <GroupBox Header="基础下载配置" Style="{StaticResource SectionGroupStyle}">
                            <StackPanel>
                                <DockPanel Style="{StaticResource FormRowStyle}">
                                    <TextBlock Style="{StaticResource RowLabelStyle}" Text="默认画质:"/>
                                    <ComboBox x:Name="QualityCombo" Height="28" DisplayMemberPath="Label" SelectedValuePath="Value"/>
                                </DockPanel>
                                <DockPanel Style="{StaticResource FormRowStyle}">
                                    <TextBlock Style="{StaticResource RowLabelStyle}" Text="最大同时下载任务:"/>
                                    <ComboBox x:Name="MaxConcurrentDownloadsCombo" Height="28" DisplayMemberPath="Label" SelectedValuePath="Value"/>
                                </DockPanel>
                                <DockPanel Style="{StaticResource FormRowStyle}">
                                    <TextBlock Style="{StaticResource RowLabelStyle}" Text="访问站点:"/>
                                    <ComboBox x:Name="SiteCombo" Height="28" SelectedValuePath="Value" IsEditable="True" IsTextSearchEnabled="False" StaysOpenOnEdit="True" SelectionChanged="SiteCombo_OnSelectionChanged" LostFocus="SiteCombo_OnEditChanged" KeyUp="SiteCombo_OnEditChanged">
                                        <ComboBox.ItemContainerStyle>
                                            <Style TargetType="ComboBoxItem">
                                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                            </Style>
                                        </ComboBox.ItemContainerStyle>
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <Grid HorizontalAlignment="Stretch">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock VerticalAlignment="Center" Text="{Binding Label}"/>
                                                    <Button x:Name="DeleteSiteButton"
                                                            Grid.Column="1"
                                                            Width="18"
                                                            Height="18"
                                                            Margin="6,0,0,0"
                                                            Padding="0"
                                                            HorizontalAlignment="Right"
                                                            VerticalAlignment="Center"
                                                            Visibility="Collapsed"
                                                            Click="SiteOptionDeleteButton_OnClick"
                                                            Tag="{Binding Value}"
                                                            Content="×"
                                                            FontSize="12"
                                                            FontWeight="Bold"
                                                            ToolTip="删除该自定义站点"/>
                                                </Grid>
                                                <DataTemplate.Triggers>
                                                    <DataTrigger Binding="{Binding IsCustom}" Value="True">
                                                        <Setter TargetName="DeleteSiteButton" Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </DataTemplate.Triggers>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                </DockPanel>
                                <TextBlock x:Name="SiteHintText"
                                           Margin="112,0,0,8"
                                           Foreground="{DynamicResource ThemeTextMutedBrush}"
                                           FontSize="11"
                                           TextWrapping="Wrap"/>
                                <DockPanel>
                                    <TextBlock Style="{StaticResource RowLabelStyle}" Text="下载队列:"/>
                                    <CheckBox x:Name="PersistQueueCheckBox" VerticalAlignment="Center" Content="关闭程序后保留下载队列"/>
                                </DockPanel>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="文件管理" Style="{StaticResource SectionGroupStyle}">
                            <StackPanel>
                                <DockPanel Style="{StaticResource FormRowStyle}">
                                    <TextBlock Style="{StaticResource RowLabelStyle}" Text="保存路径:"/>
                                    <Button DockPanel.Dock="Right" Width="68" Height="28" Margin="8,0,0,0" Click="BrowseButton_OnClick" Content="浏览"/>
                                    <TextBox x:Name="DownloadPathBox" Height="28" VerticalContentAlignment="Center" Padding="8,0" TextChanged="DownloadPathBox_OnTextChanged"/>
                                </DockPanel>
                                <TextBlock x:Name="DownloadPathHintText"
                                           Margin="112,0,0,8"
                                           Foreground="{DynamicResource ThemeTextMutedBrush}"
                                           FontSize="11"
                                           TextWrapping="Wrap"/>
                                <DockPanel>
                                    <TextBlock Style="{StaticResource RowLabelStyle}" Text="命名规则:"/>
                                    <ComboBox x:Name="NamingRuleCombo" Height="28" DisplayMemberPath="Label" SelectedValuePath="Value" SelectionChanged="NamingRuleCombo_OnSelectionChanged"/>
                                </DockPanel>
                                <TextBlock x:Name="NamingPreviewText"
                                           Margin="112,6,0,0"
                                           Foreground="{DynamicResource ThemeTextMutedBrush}"
                                           FontSize="11"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="界面设置">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="8,8,8,0">
                    <StackPanel>
                        <GroupBox Header="显示选项" Style="{StaticResource SectionGroupStyle}">
                            <StackPanel>
                                <DockPanel Style="{StaticResource FormRowStyle}">
                                    <TextBlock Style="{StaticResource RowLabelStyle}" Text="界面主题:"/>
                                    <ComboBox x:Name="ThemeModeCombo" Height="28" DisplayMemberPath="Label" SelectedValuePath="Value"/>
                                </DockPanel>
                                <CheckBox x:Name="ShowListCoversCheckBox" Margin="0,0,0,8" Content="在列表中显示视频封面"/>
                                <CheckBox x:Name="CompactModeCheckBox" Content="启用精简模式"/>
                            </StackPanel>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="详情设置">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="8,8,8,0">
                    <StackPanel>
                        <GroupBox Header="自定义详情面板显示项" Style="{StaticResource SectionGroupStyle}">
                            <StackPanel>
                                <CheckBox x:Name="ShowTitleCheckBox" Margin="0,0,0,8" Content="标题"/>
                                <CheckBox x:Name="ShowUploadDateCheckBox" Margin="0,0,0,8" Content="上传日期"/>
                                <CheckBox x:Name="ShowLikesCheckBox" Margin="0,0,0,8" Content="点赞"/>
                                <CheckBox x:Name="ShowViewsCheckBox" Margin="0,0,0,8" Content="观看次数"/>
                                <CheckBox x:Name="ShowDurationCheckBox" Margin="0,0,0,8" Content="时长"/>
                                <CheckBox x:Name="ShowTagsCheckBox" Margin="0,0,0,8" Content="标签"/>
                                <CheckBox x:Name="ShowCoverCheckBox" Margin="0,0,0,8" Content="封面(查看按钮)"/>
                                <CheckBox x:Name="ShowRelatedVideosCheckBox" Content="相关视频"/>
                            </StackPanel>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <Border Grid.Row="1" Margin="-10,8,-10,0" Padding="10,8,10,10" Background="{DynamicResource ThemeSurfaceFooterBrush}" BorderBrush="{DynamicResource ThemeBorderBrush}" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Width="96" Height="32" IsDefault="True" Click="ConfirmButton_OnClick" Content="保存设置" Background="{DynamicResource ThemeAccentBrush}" Foreground="{DynamicResource ThemeAccentForegroundBrush}" BorderBrush="{DynamicResource ThemeAccentBrush}"/>
                <Button Width="74" Height="32" Margin="8,0,0,0" IsCancel="True" Content="取消"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
